{% extends 'partials/base.html.twig' %}

{% block content %}
    <div class="center-content">
        {{ page.content }}
    </div>

    <div id="rss-feed">
        <h2>Recent posts</h2>
        <ul id="rss-feed-list">
            {% if fetchMediumRSS is not empty %}
                {{ fetchMediumRSS|raw }}
            {% else %}
                <li style="list-style-type:none;">{{ 'PLUGIN_MEDIUMRSS.NO_POSTS'|t }}</li>
            {% endif %}
        </ul>
    </div>
{% endblock %}
